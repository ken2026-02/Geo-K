{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "learning-pack-v1.schema.json",
  "title": "Learning Pack v1",
  "type": "object",
  "required": ["schema_version", "pack_id", "items"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "1.0" },
    "pack_id": { "type": "string", "minLength": 1 },
    "source_report": { "type": "object" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "content"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "enum": ["word", "phrase", "sentence", "concept"] },
          "content": { "type": "string", "minLength": 1 },
          "meaning": { "type": "string" },
          "example": { "type": "string" },
          "note": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
