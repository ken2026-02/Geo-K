{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "transformation-review-pack-v1.schema.json",
  "title": "Transformation Review Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transformation_batch_id",
    "source_learning_pack_id",
    "transformation_method",
    "candidates"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "transformation_batch_id": { "type": "string", "minLength": 1 },
    "source_learning_pack_id": { "type": "string", "minLength": 1 },
    "source_learning_export_id": { "type": "string", "minLength": 1 },
    "transformation_method": { "enum": ["ai_assisted", "manual", "hybrid"] },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "candidate_id",
              "proposed_target_type",
              "proposed_fields",
              "supporting_learning_item_ids",
              "confidence",
              "reviewer_decision"
            ],
            "properties": {
              "candidate_id": { "type": "string", "minLength": 1 },
              "proposed_target_type": { "const": "geo_material" },
              "proposed_fields": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "category", "description", "key_properties", "engineering_behaviour", "reporting_expressions"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "category": { "type": "string", "minLength": 1 },
                  "description": { "type": "string", "minLength": 1 },
                  "key_properties": { "type": "array", "items": { "type": "string" } },
                  "engineering_behaviour": { "type": "array", "items": { "type": "string" } },
                  "reporting_expressions": { "type": "array", "items": { "type": "string" } }
                }
              },
              "supporting_learning_item_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "confidence": { "enum": ["high", "medium", "low"] },
              "ambiguity_flags": { "type": "array", "items": { "type": "string" } },
              "reviewer_decision": { "enum": ["pending", "accepted", "rejected", "needs_split", "needs_merge", "needs_rewrite"] },
              "reviewer_notes": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "candidate_id",
              "proposed_target_type",
              "proposed_fields",
              "supporting_learning_item_ids",
              "confidence",
              "reviewer_decision"
            ],
            "properties": {
              "candidate_id": { "type": "string", "minLength": 1 },
              "proposed_target_type": { "const": "geo_feature" },
              "proposed_fields": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "category", "mechanism", "description", "typical_conditions", "field_indicators", "engineering_assessment", "reporting_expressions"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "category": { "type": "string", "minLength": 1 },
                  "mechanism": { "type": "string", "minLength": 1 },
                  "description": { "type": "string", "minLength": 1 },
                  "typical_conditions": { "type": "array", "items": { "type": "string" } },
                  "field_indicators": { "type": "array", "items": { "type": "string" } },
                  "engineering_assessment": { "type": "array", "items": { "type": "string" } },
                  "reporting_expressions": { "type": "array", "items": { "type": "string" } }
                }
              },
              "supporting_learning_item_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "confidence": { "enum": ["high", "medium", "low"] },
              "ambiguity_flags": { "type": "array", "items": { "type": "string" } },
              "reviewer_decision": { "enum": ["pending", "accepted", "rejected", "needs_split", "needs_merge", "needs_rewrite"] },
              "reviewer_notes": { "type": "string" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "candidate_id",
              "proposed_target_type",
              "proposed_fields",
              "supporting_learning_item_ids",
              "confidence",
              "reviewer_decision"
            ],
            "properties": {
              "candidate_id": { "type": "string", "minLength": 1 },
              "proposed_target_type": { "const": "strategy" },
              "proposed_fields": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "category", "trigger_conditions", "actions", "reporting_expressions"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "category": { "type": "string", "minLength": 1 },
                  "trigger_conditions": { "type": "array", "items": { "type": "string" } },
                  "actions": { "type": "array", "items": { "type": "string" } },
                  "reporting_expressions": { "type": "array", "items": { "type": "string" } }
                }
              },
              "supporting_learning_item_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "confidence": { "enum": ["high", "medium", "low"] },
              "ambiguity_flags": { "type": "array", "items": { "type": "string" } },
              "reviewer_decision": { "enum": ["pending", "accepted", "rejected", "needs_split", "needs_merge", "needs_rewrite"] },
              "reviewer_notes": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
